<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 基础权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- 位置权限 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <!-- 存储权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    
    <!-- 音频权限 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    
    <!-- 电话权限 -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    
    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- 前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    
    <!-- 通知权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 开机启动 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- 查询所有应用 -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".CarLauncherApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CarLauncher"
        tools:targetApi="31">

        <!-- 主界面 -->
        <activity
            android:name=".ui.HomeActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.CarLauncher.Car">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- 设置界面 -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/settings"
            android:parentActivityName=".ui.HomeActivity"
            android:screenOrientation="landscape" />

        <!-- 应用管理 -->
        <activity
            android:name=".ui.AppManagerActivity"
            android:exported="false"
            android:label="@string/app_manager"
            android:parentActivityName=".ui.HomeActivity"
            android:screenOrientation="landscape" />

        <!-- 主题设置 -->
        <activity
            android:name=".ui.ThemeActivity"
            android:exported="false"
            android:label="@string/theme"
            android:parentActivityName=".ui.HomeActivity"
            android:screenOrientation="landscape" />

        <!-- 语音助手 -->
        <activity
            android:name=".ui.VoiceAssistantActivity"
            android:exported="false"
            android:label="@string/voice_assistant"
            android:parentActivityName=".ui.HomeActivity"
            android:screenOrientation="landscape" />

        <!-- 导航界面 -->
        <activity
            android:name=".navigation.NavigationActivity"
            android:exported="false"
            android:label="@string/navigation"
            android:parentActivityName=".ui.HomeActivity"
            android:screenOrientation="landscape"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation" />

        <!-- 媒体播放器 -->
        <activity
            android:name=".ui.MediaActivity"
            android:exported="false"
            android:label="@string/music"
            android:parentActivityName=".ui.HomeActivity"
            android:screenOrientation="landscape" />

        <!-- 视频播放器 -->
        <activity
            android:name=".media.VideoPlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|smallestScreenSize"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.CarLauncher" />

        <!-- 本地音乐播放器 -->
        <activity
            android:name=".media.LocalMusicPlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.CarLauncher" />

        <!-- 本地视频播放器 -->
        <activity
            android:name=".media.LocalVideoPlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|smallestScreenSize"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.CarLauncher" />

        <!-- 插件管理 -->
        <activity
            android:name=".plugin.PluginActivity"
            android:exported="false"
            android:label="@string/plugin_manager"
            android:parentActivityName=".ui.SettingsActivity"
            android:screenOrientation="landscape" />

        <!-- 悬浮球服务 -->
        <service
            android:name=".service.FloatingBallService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- 画中画导航服务 -->
        <service
            android:name=".pip.PipNavigationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- 媒体浏览器服务 -->
        <service
            android:name=".media.MediaBrowserService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

        <!-- 开机启动接收器 -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
