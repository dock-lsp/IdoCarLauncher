<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.CarLauncher" parent="Theme.Material3.Dark.NoActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        
        <!-- 背景色 -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- 文本颜色 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        
        <!-- 窗口属性 -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        
        <!-- 控件样式 -->
        <item name="materialCardViewStyle">@style/Widget.CarLauncher.CardView</item>
        <item name="buttonStyle">@style/Widget.CarLauncher.Button</item>
    </style>
    
    <!-- 车机专用主题 -->
    <style name="Theme.CarLauncher.Car" parent="Theme.CarLauncher">
        <item name="android:windowSwipeToDismiss">false</item>
    </style>
    
    <!-- CardView 样式 -->
    <style name="Widget.CarLauncher.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <!-- 按钮样式 -->
    <style name="Widget.CarLauncher.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <!-- 圆形按钮 -->
    <style name="Widget.CarLauncher.Button.Circle" parent="Widget.Material3.Button.IconButton">
        <item name="iconSize">32dp</item>
    </style>
    
    <!-- 快捷方式按钮 -->
    <style name="Widget.CarLauncher.ShortcutButton">
        <item name="android:background">@drawable/bg_shortcut</item>
        <item name="android:padding">12dp</item>
    </style>
    
    <!-- 文字样式 -->
    <style name="Text.CarLauncher.Headline">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="Text.CarLauncher.Title">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="Text.CarLauncher.Subtitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="Text.CarLauncher.Body">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="Text.CarLauncher.Caption">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
